# ─── ClawFin Configuration ───────────────────────────────────────────
# Copy to .env and fill in your values

# Auth — set a password to protect your instance
CLAWFIN_PASSWORD=

# Database path (Docker: /data/clawfin.db, Local: ~/.clawfin/clawfin.db)
# CLAWFIN_DB_PATH=/data/clawfin.db

# SimpleFin — paste your access URL after running setup
# CLAWFIN_SIMPLEFIN_ACCESS_URL=

# AI Provider — ollama (default), openai, anthropic
CLAWFIN_AI_PROVIDER=ollama
CLAWFIN_AI_MODEL=llama3.1
CLAWFIN_AI_BASE_URL=http://ollama:11434
# CLAWFIN_AI_API_KEY=

# Security
CLAWFIN_SECRET_KEY=change-me-to-a-random-string
