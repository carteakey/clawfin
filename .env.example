# ─── ClawFin Configuration ───────────────────────────────────────────
# Copy to .env and fill in your values.

# ── Auth ─────────────────────────────────────────────────────────────
# Set a password to gate the UI. Leave empty to disable auth (dev only).
CLAWFIN_PASSWORD=
# JWT signing key. Generate with: openssl rand -hex 32
CLAWFIN_SECRET_KEY=change-me-to-a-random-string
# Token lifetime in hours
CLAWFIN_TOKEN_EXPIRE_HOURS=72
# Separate token for cron/n8n automation endpoints.
# Generate with: openssl rand -hex 32
# CLAWFIN_AUTOMATION_TOKEN=

# ── Database ─────────────────────────────────────────────────────────
# Docker: /data/clawfin.db · Local: ~/.clawfin/clawfin.db
# CLAWFIN_DB_PATH=/data/clawfin.db

# ── SimpleFin (optional) ─────────────────────────────────────────────
# After running setup in the UI, paste the returned access URL here.
# CLAWFIN_SIMPLEFIN_ACCESS_URL=
# Accounts are considered sync-stale when last successful SimpleFIN sync is this many days old.
CLAWFIN_SIMPLEFIN_STALE_DAYS=3

# ── AI Provider ──────────────────────────────────────────────────────
# Provider: ollama (default), openai, anthropic. Can also be set from Settings.
CLAWFIN_AI_PROVIDER=ollama
CLAWFIN_AI_MODEL=llama3.1
# Ollama: http://localhost:11434 (local) or http://ollama:11434 (docker)
# OpenAI: https://api.openai.com
# Anthropic: https://api.anthropic.com
CLAWFIN_AI_BASE_URL=http://localhost:11434
# Required for openai/anthropic. Not used for ollama.
# CLAWFIN_AI_API_KEY=

# ── Server ───────────────────────────────────────────────────────────
CLAWFIN_HOST=0.0.0.0
CLAWFIN_PORT=8000
# Comma-separated list of allowed frontend origins.
# CLAWFIN_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
